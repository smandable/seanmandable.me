---
import Layout from '../layouts/Layout.astro';
import { profile, roles, earlyCareer, education, tools, competencies } from '../data/resume';
---

<Layout title="Resume">
  <section class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Resume</h1>
      <p class="mt-1 text-slate-600">
        {profile.title} · {profile.location}
      </p>
    </div>
    <a
      href="/sean-mandable-resume.pdf"
      class="inline-flex items-center rounded-md bg-sky-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-sky-700"
    >
      Download PDF
    </a>
  </section>

  <section class="mt-10 rounded-lg border border-slate-200 p-6">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">Summary</h2>
    <p class="mt-3 text-base leading-relaxed text-slate-700">{profile.summary}</p>
  </section>

  <section class="mt-12">
    <h2 class="text-2xl font-semibold tracking-tight">Experience</h2>
    <div class="mt-6 space-y-10">
      {roles.map((role) => (
        <article class="border-l-2 border-slate-200 pl-6">
          <header class="flex flex-wrap items-baseline justify-between gap-2">
            <div>
              <h3 class="text-lg font-semibold">
                {role.company}
                <span class="font-normal text-slate-500"> · {role.location}</span>
              </h3>
              <p class="text-sky-600">{role.title}</p>
            </div>
            <span class="text-sm text-slate-500">{role.years}</span>
          </header>
          {role.blurb && <p class="mt-1 text-sm italic text-slate-500">{role.blurb}</p>}
          {role.quote && (
            <blockquote class="mt-4 rounded-md bg-slate-50 p-4 text-sm italic text-slate-700">
              <p>“{role.quote.text}”</p>
              <footer class="mt-2 text-xs not-italic text-slate-500">— {role.quote.attribution}</footer>
            </blockquote>
          )}
          <ul class="mt-4 space-y-2 text-sm leading-relaxed text-slate-700">
            {role.bullets.map((b) => (
              <li class="flex gap-2">
                <span class="mt-1.5 inline-block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-sky-600" aria-hidden="true"></span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-2xl font-semibold tracking-tight">Early Career</h2>
    <ul class="mt-4 text-sm text-slate-700">
      {earlyCareer.map((e) => (
        <li><strong>{e.company}</strong> — {e.title}</li>
      ))}
    </ul>
  </section>

  <section class="mt-12 grid gap-10 md:grid-cols-2">
    <div>
      <h2 class="text-2xl font-semibold tracking-tight">Education</h2>
      <ul class="mt-4 space-y-3 text-sm text-slate-700">
        {education.map((e) => (
          <li>
            <div class="font-medium">{e.school}</div>
            <div class="text-slate-500">{e.degree}</div>
          </li>
        ))}
      </ul>
    </div>
    <div>
      <h2 class="text-2xl font-semibold tracking-tight">Core Competencies</h2>
      <ul class="mt-4 grid grid-cols-2 gap-x-4 gap-y-1 text-sm text-slate-700">
        {competencies.map((c) => (
          <li>{c}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-2xl font-semibold tracking-tight">Tools & Technologies</h2>
    <div class="mt-4 flex flex-wrap gap-2">
      {tools.map((t) => (
        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">{t}</span>
      ))}
    </div>
  </section>
</Layout>
