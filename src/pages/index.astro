---
import Layout from '../layouts/Layout.astro';
import { profile, tools, competencies } from '../data/resume';
---

<Layout>
  <section class="flex flex-col items-start gap-10 md:flex-row md:items-center">
    <img
      src="/profile.jpg"
      alt={profile.name}
      class="h-40 w-40 rounded-full object-cover shadow-md md:h-48 md:w-48"
    />
    <div class="flex-1">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">{profile.name}</h1>
      <p class="mt-2 text-lg text-sky-600">{profile.title}</p>
      <p class="mt-1 text-sm text-slate-500">{profile.tagline}</p>
      <p class="mt-6 text-base leading-relaxed text-slate-700">{profile.summary}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/resume"
          class="inline-flex items-center rounded-md bg-sky-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-sky-700"
        >
          View Resume
        </a>
        <a
          href="/contact"
          class="inline-flex items-center rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition-colors hover:border-sky-600 hover:text-sky-600"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </section>

  <section class="mt-20">
    <h2 class="text-2xl font-semibold tracking-tight">Core Competencies</h2>
    <ul class="mt-6 grid grid-cols-1 gap-2 text-sm text-slate-700 sm:grid-cols-2 md:grid-cols-3">
      {competencies.map((c) => (
        <li class="rounded-md border border-slate-200 px-3 py-2">{c}</li>
      ))}
    </ul>
  </section>

  <section class="mt-20">
    <h2 class="text-2xl font-semibold tracking-tight">Tools & Technologies</h2>
    <div class="mt-6 flex flex-wrap gap-2">
      {tools.map((t) => (
        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">
          {t}
        </span>
      ))}
    </div>
  </section>
</Layout>
