---
import { profile } from '../data/resume';
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-slate-200 py-8 text-sm text-slate-500">
  <div class="mx-auto flex max-w-5xl flex-col items-center gap-2 px-6 sm:flex-row sm:justify-between">
    <p>© {year} {profile.name}</p>
    <nav class="footer-links flex flex-wrap items-center justify-center" aria-label="Footer">
      <a href="/contact" class="hover:text-accent-600">Contact</a>
      <a href={`mailto:${profile.email}`} class="hover:text-accent-600" data-umami-event="contact-email">Email</a>
      <a href={profile.github} class="hover:text-accent-600" rel="noreferrer" target="_blank" data-umami-event="external-link-github">GitHub</a>
      <a href={profile.linkedin} class="hover:text-accent-600" rel="noreferrer" target="_blank" data-umami-event="external-link-linkedin">LinkedIn</a>
      <a href="/sean-mandable-resume.pdf" class="hover:text-accent-600" download="Sean-Mandable-Resume.pdf" data-umami-event="download-resume">Resume (PDF)</a>
    </nav>
  </div>
</footer>

<style>
  /*
   * Interpunct (U+00B7) separators between footer links, drawn in CSS so the
   * character never lives in the markup. Decorative content in ::before is
   * typically skipped by screen readers and doesn't leak into copy-paste.
   */
  .footer-links a + a::before {
    content: "\00B7";
    padding: 0 0.5rem;
    color: var(--color-slate-300, #cbd5e1);
  }
</style>
