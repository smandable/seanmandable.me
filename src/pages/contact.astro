---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.vue';
import { profile } from '../data/resume';

const endpoint = import.meta.env.PUBLIC_FORMSPREE_ENDPOINT ?? '';
---

<Layout title="Contact">
  <section class="mx-auto max-w-2xl">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Get in Touch</h1>
    <p class="mt-3 text-slate-700">
      Interested in hiring me? Just want to say hi? Send a message below, or
      email <a class="text-sky-600 hover:underline" href={`mailto:${profile.email}`}>{profile.email}</a>.
    </p>

    <div class="mt-10">
      <ContactForm endpoint={endpoint} client:load />
    </div>

    <div class="mt-12 grid gap-4 text-sm text-slate-700 sm:grid-cols-2">
      <div>
        <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Email</div>
        <a class="hover:text-sky-600" href={`mailto:${profile.email}`}>{profile.email}</a>
      </div>
      <div>
        <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Phone</div>
        <a class="hover:text-sky-600" href={`tel:${profile.phone.replace(/\D/g, '')}`}>{profile.phone}</a>
      </div>
    </div>
  </section>
</Layout>
