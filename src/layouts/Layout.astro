---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { profile } from '../data/resume';

type Props = {
  title?: string;
  description?: string;
};

const { title, description = `${profile.name} — ${profile.title}` } = Astro.props;
const fullTitle = title ? `${title} — ${profile.name}` : profile.name;

// Bump this when any /favicon.* or /apple-touch-icon.png changes so browsers
// refetch instead of serving stale cached versions.
const ICON_VERSION = '2';
---

<!doctype html>
<html lang="en" class="bg-white text-slate-900 antialiased">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${ICON_VERSION}`} />
    <link rel="icon" href={`/favicon.ico?v=${ICON_VERSION}`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`/apple-touch-icon.png?v=${ICON_VERSION}`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content="Sean Mandable — Senior Software Engineer & Full-Stack Dev" />
    <meta property="og:description" content="Full-stack web (Vue, Angular, TypeScript, Node) + Swift/SwiftUI. I notice when things are off and can’t quite leave them there." />
    <meta property="og:image" content="https://www.seanmandable.me/og-image.png" />
    <meta property="og:url" content="https://www.seanmandable.me/" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Sean Mandable — Senior Software Engineer & Full-Stack Dev" />
    <meta name="twitter:description" content="Full-stack web (Vue, Angular, TypeScript, Node) + Swift/SwiftUI. I notice when things are off and can’t quite leave them there." />
    <meta name="twitter:image" content="https://www.seanmandable.me/og-image.png" />
    <title>{fullTitle}</title>
    {import.meta.env.PROD && (
      <script
        is:inline
        defer
        data-website-id="7ccf0608-b402-47a9-8a95-36710ac0492f"
        src="https://cloud.umami.is/script.js"
      />
    )}
  </head>
  <body class="min-h-screen">
    <header class="border-b border-slate-200">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
        <a href="/" class="text-lg font-semibold tracking-tight">{profile.name}</a>
        <Nav />
      </div>
    </header>
    <main class="mx-auto max-w-5xl px-6 py-12">
      <slot />
    </main>
    <Footer />
  </body>
</html>
