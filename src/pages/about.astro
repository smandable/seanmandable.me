---
import Layout from '../layouts/Layout.astro';
import { Content, frontmatter } from '../about.md';
---

<Layout title={frontmatter.title} description={frontmatter.description}>
  <section>
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{frontmatter.title}</h1>
  </section>

  <article class="prose mt-10 max-w-none">
    <Content />
  </article>
</Layout>
