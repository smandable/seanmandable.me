---
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/work', label: 'Work' },
  { href: '/projects', label: 'Projects' },
  { href: '/writing', label: 'Writing' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<!-- Desktop nav (inline on sm+) -->
<nav class="hidden items-center gap-6 text-sm font-medium sm:flex">
  {links.map(({ href, label }) => {
    const active = isActive(href);
    return (
      <a
        href={href}
        class:list={[
          'transition-colors hover:text-sky-600',
          active ? 'text-sky-600' : 'text-slate-600',
        ]}
        aria-current={active ? 'page' : undefined}
      >
        {label}
      </a>
    );
  })}
</nav>

<!-- Mobile nav (hamburger) -->
<div class="relative sm:hidden">
  <button
    type="button"
    data-nav-toggle
    aria-label="Open menu"
    aria-controls="mobile-nav"
    aria-expanded="false"
    class="-m-2 inline-flex items-center justify-center rounded-md p-2 text-slate-700 hover:text-sky-600"
  >
    <svg data-nav-icon-open    class="h-6 w-6"        fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
    <svg data-nav-icon-close   class="hidden h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
  </button>

  <div
    id="mobile-nav"
    data-nav-menu
    hidden
    class="absolute right-0 z-50 mt-2 w-48 origin-top-right rounded-md border border-slate-200 bg-white py-2 shadow-lg"
  >
    <nav class="flex flex-col text-sm font-medium">
      {links.map(({ href, label }) => {
        const active = isActive(href);
        return (
          <a
            href={href}
            class:list={[
              'px-4 py-2 transition-colors hover:bg-slate-50 hover:text-sky-600',
              active ? 'text-sky-600' : 'text-slate-700',
            ]}
            aria-current={active ? 'page' : undefined}
          >
            {label}
          </a>
        );
      })}
    </nav>
  </div>
</div>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const menu = document.querySelector<HTMLElement>('[data-nav-menu]');
  const iconOpen = document.querySelector<HTMLElement>('[data-nav-icon-open]');
  const iconClose = document.querySelector<HTMLElement>('[data-nav-icon-close]');

  function setOpen(open: boolean): void {
    if (!btn || !menu || !iconOpen || !iconClose) return;
    menu.hidden = !open;
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    iconOpen.classList.toggle('hidden', open);
    iconClose.classList.toggle('hidden', !open);
  }

  btn?.addEventListener('click', (e) => {
    e.stopPropagation();
    setOpen(menu?.hidden ?? true);
  });

  document.addEventListener('click', (e) => {
    if (!menu || menu.hidden) return;
    const target = e.target as Node;
    if (menu.contains(target) || btn?.contains(target)) return;
    setOpen(false);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>
