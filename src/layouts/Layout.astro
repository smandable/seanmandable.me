---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { profile } from '../data/resume';

type Props = {
  title?: string;
  description?: string;
};

const { title, description = `${profile.name} — ${profile.title}` } = Astro.props;
const fullTitle = title ? `${title} — ${profile.name}` : profile.name;

// Bump this when any /favicon.* or /apple-touch-icon.png changes so browsers
// refetch instead of serving stale cached versions.
const ICON_VERSION = '1';
---

<!doctype html>
<html lang="en" class="bg-white text-slate-900 antialiased">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${ICON_VERSION}`} />
    <link rel="icon" href={`/favicon.ico?v=${ICON_VERSION}`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`/apple-touch-icon.png?v=${ICON_VERSION}`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen">
    <header class="border-b border-slate-200">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
        <a href="/" class="text-lg font-semibold tracking-tight">{profile.name}</a>
        <Nav />
      </div>
    </header>
    <main class="mx-auto max-w-5xl px-6 py-12">
      <slot />
    </main>
    <Footer />
  </body>
</html>
